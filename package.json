{
  "name": "ts-maps",
  "type": "module",
  "version": "0.2.7",
  "private": true,
  "description": "A modern vector map library.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/ts-maps",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/ts-maps.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/ts-maps/issues"
  },
  "keywords": [
    "maps",
    "vector",
    "map",
    "development",
    "typescript",
    "stacks",
    "typescript",
    "javascript"
  ],
  "exports": {
    ".": {
      "import": "./packages/ts-maps/dist/index.js"
    }
  },
  "module": "./packages/ts-maps/dist/index.js",
  "types": "./packages/ts-maps/dist/index.d.ts",
  "files": [
    "README.md",
    "packages/post/dist"
  ],
  "scripts": {
    "build": "bun --bun scripts/build-all.ts",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i",
    "test": "bun --bun scripts/test-all.ts",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write",
    "changelog": "bunx logsmith --verbose",
    "changelog:generate": "bunx logsmith --output CHANGELOG.md",
    "release": "bun run changelog:generate && bunx --bun bumpx prompt --recursive",
    "typecheck": "bunx tsc --noEmit",
    "bench:ts-maps": "cd packages/ts-maps && bun run bench",
    "playground:core-map": "bun --bun run playground/core-map/serve.ts",
    "dev:docs": "bun --bun bunpress dev docs",
    "build:docs": "bun --bun bunpress build docs",
    "preview:docs": "bun --bun bunpress preview docs"
  },
  "devDependencies": {
    "@stacksjs/bunpress": "^0.1.4",
    "better-dx": "^0.2.7"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      }
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  },
  "workspaces": [
    "packages/**",
    "playground",
    "playground/core-map"
  ]
}
