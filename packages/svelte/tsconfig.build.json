{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "allowImportingTsExtensions": false,
    // The root tsconfig points `ts-maps` at the package source, which
    // pulls those files into the program and trips `rootDir`. For build
    // we want types to come from the already-built dist instead.
    "baseUrl": ".",
    "paths": {
      "ts-maps": ["../ts-maps/dist/index.d.ts"],
      "ts-maps/*": ["../ts-maps/dist/core-map/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.svelte", "dist", "node_modules", "test"]
}
