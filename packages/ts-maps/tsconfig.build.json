{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/**/*.test.ts",
    "dist",
    "node_modules",
    "test",
    "scripts",
    "bench"
  ]
}
