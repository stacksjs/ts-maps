{
  "name": "@ts-maps/solid",
  "type": "module",
  "version": "0.2.7",
  "description": "SolidJS bindings for ts-maps.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/ts-maps/tree/main/packages/solid#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/ts-maps.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/ts-maps/issues"
  },
  "keywords": [
    "solid",
    "solidjs",
    "maps",
    "interactive",
    "typescript",
    "ts-maps",
    "vector"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./src/index.tsx",
      "development": "./src/index.tsx",
      "import": "./src/index.tsx"
    },
    "./styles.css": "./../ts-maps/src/core-map/ts-maps.css"
  },
  "main": "./src/index.tsx",
  "module": "./src/index.tsx",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun --bun tsc -p tsconfig.build.json",
    "prepublishOnly": "bun --bun run build",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "dependencies": {
    "ts-maps": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": ">=1.8"
  },
  "devDependencies": {
    "solid-js": "^1.9.12",
    "typescript": "^5.9.3"
  }
}
